# Copy to .env and fill in. Keep .env private (chmod 600); it is gitignored.

# GPU backend: cuda (NVIDIA, default) | openvino (Intel Arc/iGPU) | vulkan (AMD) | cpu
# Set in .env for docker compose, or pass --build-arg TORCH_BACKEND=... to docker build.
TORCH_BACKEND=cuda

# Login password for the web UI. Leave blank to disable auth entirely.
VELLICHOR_PASSWORD=change-me

# Session-cookie signing key. Generate with: openssl rand -hex 32
# (changing it invalidates existing logins)
SECRET_KEY=

# Optional: push a notification when a conversion finishes.
# ntfy example:   http://<host>:8087/vellichor
# gotify example: http://<host>:8070/message?token=...
NOTIFY_URL=
